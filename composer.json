{
    "name": "devcraftclub/notkinopoisk",
    "description": "PHP wrapper для Kinopoisk Unofficial API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Maxim Harder",
            "email": "dev@devcraft.club"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8",
        "ext-json": "*",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "NotKinopoisk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NotKinopoisk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs": "phpcs src/",
        "cs-fix": "phpcbf src/"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
} 