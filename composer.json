{
    "name": "devcraftclub/kinopoiskapiunofficialtech",
    "description": "PHP wrapper для Kinopoisk Unofficial API",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/DevCraftClub/NotKinopoiskPHP",
    "repository": {
        "type": "git",
        "url": "https://github.com/DevCraftClub/NotKinopoiskPHP.git"
    },
    "keywords": [
        "kinopoisk",
        "api",
        "php",
        "wrapper",
        "films",
        "movies",
        "series",
        "tv-shows",
        "unofficial"
    ],
    "support": {
        "issues": "https://github.com/DevCraftClub/NotKinopoiskPHP/issues",
        "source": "https://github.com/DevCraftClub/NotKinopoiskPHP"
    },
    "authors": [
        {
            "name": "Maxim Harder",
            "email": "dev@devcraft.club"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.8",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "suggest": {
        "ext-openssl": "Для HTTPS соединений",
        "ext-zlib": "Для сжатия данных",
        "ext-intl": "Для интернационализации"
    },
    "autoload": {
        "psr-4": {
            "NotKinopoisk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NotKinopoisk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs": "phpcs src/",
        "cs-fix": "phpcbf src/"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
} 